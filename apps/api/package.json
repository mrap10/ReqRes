{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch index.ts",
    "dev:api-only": "WORKER_ENABLED=false bun run --watch index.ts",
    "build": "bun build index.ts --outdir ./dist --target=bun && bun build worker.ts --outdir ./dist --target=bun",
    "start": "bun run dist/index.js",
    "worker:dev": "bun run --watch worker.ts",
    "worker:start": "bun run worker.ts",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@reqres/eslint-config": "*",
    "@reqres/typescript-config": "*",
    "@types/bun": "latest",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.6",
    "@reqres/types": "*",
    "@reqres/utils": "*",
    "@sentry/node": "^10.36.0",
    "@sentry/profiling-node": "^10.36.0",
    "@types/cors": "^2.8.19",
    "axios": "^1.13.2",
    "better-auth": "^1.4.16",
    "bullmq": "^5.66.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.1",
    "zod": "^4.3.5"
  }
}
