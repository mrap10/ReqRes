PORT=4000
NODE_ENV=development

# Runner
RUNNER_BASE_URL=http://localhost:5000
RUNNER_SHARED_SECRET=change-me-to-a-long-random-string

# Web / Auth
WEB_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/reqres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
WORKER_CONCURRENCY=5
WORKER_ENABLED=true

TRUST_PROXY=false

# Optional
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SENTRY_DSN=
# RESEND_API_KEY=
# LOG_LEVEL=info